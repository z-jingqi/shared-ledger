{
  "name": "shared-ledger",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @shared-ledger/web --filter @shared-ledger/api dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "pnpm --filter @shared-ledger/shared test && pnpm --filter @shared-ledger/import test && pnpm --filter @shared-ledger/web test",
    "test:integration": "pnpm --filter @shared-ledger/api test",
    "test:e2e": "pnpm --filter @shared-ledger/web test:e2e",
    "test:coverage": "pnpm --filter @shared-ledger/web test:coverage && pnpm --filter @shared-ledger/api test:coverage",
    "lint": "pnpm -r --if-present lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:generate": "pnpm --filter @shared-ledger/db generate",
    "db:migrate:local": "pnpm --filter @shared-ledger/api d1:migrate:local",
    "cf:dev": "pnpm --filter @shared-ledger/api dev",
    "cf:deploy:dev": "node scripts/prepare-wrangler-config.mjs api dev && pnpm --filter @shared-ledger/api exec wrangler deploy --config wrangler.generated-api-dev.json",
    "cf:deploy:prod": "node scripts/prepare-wrangler-config.mjs api prod && pnpm --filter @shared-ledger/api exec wrangler deploy --config wrangler.generated-api-prod.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "prettier": "^3.5.3",
    "ts-morph": "^28.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
