# Browser: use the same-origin API prefix. Local Vite proxies /api to the API worker.
VITE_API_URL=/api

# Cloudflare deploy / GitHub Actions values. Never commit real secrets.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID_PROD=
