ALEPH_AI_SERVICE_PREVIEW=aleph-ai-orchestrator-preview
ALEPH_AI_SERVICE_PROD=aleph-ai-orchestrator
ALEPH_AI_ENV_PREVIEW=preview
ALEPH_AI_ENV_PROD=prod
ALEPH_AI_SERVICE_TOKEN=
ALEPH_TOOLS_SERVICE_PREVIEW=aleph-tools-gateway-preview
ALEPH_TOOLS_SERVICE_PROD=aleph-tools-gateway-prod
