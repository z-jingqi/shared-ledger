{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@aleph-ai-platform/ai-client": ["../aleph-ai-platform/packages/ai-client/src/index.ts"],
      "@aleph-ai-platform/shared": ["../aleph-ai-platform/packages/shared/src/index.ts"]
    }
  }
}
