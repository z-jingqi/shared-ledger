{
  "name": "@shared-ledger/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.local.jsonc",
    "dev:ai": "wrangler dev --config wrangler.ai.local.jsonc",
    "dev:containers": "wrangler dev --config wrangler.container.local.jsonc",
    "build": "wrangler deploy --dry-run --config wrangler.local.jsonc",
    "build:containers": "wrangler deploy --dry-run --config wrangler.container.local.jsonc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test --ignore-pattern src/worker-configuration.d.ts --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json",
    "d1:migrate:local": "wrangler d1 migrations apply shared-ledger-local --local --config wrangler.local.jsonc"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.0.25",
    "@hono/zod-validator": "^0.4.3",
    "@shared-ledger/ai": "workspace:*",
    "@shared-ledger/import": "workspace:*",
    "@shared-ledger/shared": "workspace:*",
    "ai": "^6.0.208",
    "hono": "^4.7.7",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "wrangler": "^4.24.3"
  }
}
